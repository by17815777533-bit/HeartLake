# HeartLake 2C2G Ubuntu Server Environment
# 用于单机精简部署：gateway + admin + backend + postgres + redis

DB_NAME=heartlake
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# 仅公开 gateway；其余服务绑定到 127.0.0.1
GATEWAY_BIND_HOST=0.0.0.0
GATEWAY_PORT=80
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8080
ADMIN_BIND_HOST=127.0.0.1
ADMIN_PORT=5173

# 2C2G 低配构建/运行参数
BACKEND_BUILD_JOBS=1
SERVER_THREADS=2
DB_POOL_SIZE=4
REDIS_POOL_SIZE=4
REDIS_MAX_POOL_SIZE=8
LOG_LEVEL=WARN

# 公网入口；没有域名时先填服务器公网 IP
PUBLIC_API_URL=http://YOUR_HOST/api
PUBLIC_WS_URL=ws://YOUR_HOST/ws/broadcast
# 允许多个来源时用英文逗号分隔，例如加上本地后台联调源：
# CORS_ALLOWED_ORIGIN=http://YOUR_HOST,http://localhost:5173
CORS_ALLOWED_ORIGIN=http://YOUR_HOST

# 管理后台
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=CHANGE_ME_ADMIN_PASSWORD_HASH

# 安全密钥
PASETO_KEY=CHANGE_ME_PASETO_KEY_AT_LEAST_32_BYTES
ADMIN_PASETO_KEY=CHANGE_ME_ADMIN_PASETO_KEY_AT_LEAST_32_BYTES

# AI 路由：
# - 2C2G 不建议在本机额外跑 Ollama；默认按外部 OpenAI-compatible API 填写
# - 如果你坚持本机 Ollama，请手动改回 AI_PROVIDER=ollama 并确保 AI_BASE_URL 可达
AI_PROVIDER=deepseek
AI_API_KEY=CHANGE_ME_AI_API_KEY
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TIMEOUT=15
AI_MAX_RETRIES=1
AI_CIRCUIT_BREAKER_FAILURES=2
AI_CIRCUIT_BREAKER_COOLDOWN_SEC=60
AI_OLLAMA_FORCE_GPU=false
AI_OLLAMA_NUM_THREAD=2
AI_OLLAMA_NUM_CTX=2048
AI_SEMANTIC_CACHE_MAX_SIZE=2000
AI_SENTIMENT_CACHE_MAX_SIZE=8000
AI_SEMANTIC_CACHE_TTL_SEC=86400
EMBEDDING_CACHE_SIZE=6000
EDGE_AI_SENTIMENT_CACHE_MAX_SIZE=4096
EDGE_AI_ONNX_ENABLED=false
EDGE_AI_ONNX_THREADS=1

# 关闭高占用的后台任务；稳定后按需逐项开启
EMBEDDING_WARMUP_ON_BOOT=false
ENABLE_LAKE_GOD_GUARDIAN=false
LAKE_GOD_STARTUP_DELAY_SEC=300
LAKE_GOD_SCAN_INTERVAL_MINUTES=60
LAKE_GOD_ZERO_INTERACTION_THRESHOLD_HOURS=6
LAKE_GOD_SCAN_BATCH_SIZE=1
ENABLE_EMOTION_TRACKING=false
EMOTION_TRACKING_STARTUP_DELAY_SEC=300
EMOTION_TRACKING_SCAN_INTERVAL_MINUTES=60
ENABLE_USER_FOLLOWUP=false
USER_FOLLOWUP_STARTUP_DELAY_SEC=600
USER_FOLLOWUP_SCAN_INTERVAL_HOURS=12
ENABLE_WS_HEARTBEAT=true
REALTIME_QUIC_ENABLED=false
