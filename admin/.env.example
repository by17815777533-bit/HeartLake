# API 基础路径（默认 /api，开发时可指向后端地址）
VITE_API_BASE_URL=/api

# WebSocket 地址（如需显式覆盖，请填写完整的 /ws/broadcast 地址；默认与页面同源）
VITE_WS_URL=

# 本地 `pnpm dev` 调试时的 API 代理目标；不填则默认走 127.0.0.1:8080
# 示例：VITE_DEV_API_ORIGIN=https://YOUR_HOST
VITE_DEV_API_ORIGIN=

# 本地 `pnpm dev` 调试时的 WebSocket 代理目标；不填则从 API Origin 自动推导
# 示例：VITE_DEV_WS_ORIGIN=wss://YOUR_HOST
VITE_DEV_WS_ORIGIN=

# 应用标题
VITE_APP_TITLE=HeartLake 管理后台
