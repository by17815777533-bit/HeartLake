# HeartLake Docker Compose Environment
# 模板文件：复制为 .env 后，请先填写密码、密钥和管理员密码哈希。

DB_NAME=heartlake
DB_USER=postgres
DB_PASSWORD=
REDIS_PASSWORD=

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
PASETO_KEY=
ADMIN_PASETO_KEY=

# 本地开发默认公开所有服务端口；服务器部署建议仅公开 gateway。
GATEWAY_BIND_HOST=0.0.0.0
POSTGRES_BIND_HOST=0.0.0.0
REDIS_BIND_HOST=0.0.0.0
OLLAMA_BIND_HOST=0.0.0.0
BACKEND_BIND_HOST=0.0.0.0
ADMIN_BIND_HOST=0.0.0.0

GATEWAY_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
OLLAMA_PORT=11434
BACKEND_PORT=8080
ADMIN_PORT=5173

# 本地开发默认走 Ollama；低配服务器请使用 server-lite 模式。
AI_PROVIDER=ollama
AI_API_KEY=
AI_BASE_URL=http://localhost:11434
AI_MODEL=heartlake-qwen
AI_OLLAMA_FORCE_GPU=false
AI_OLLAMA_NUM_GPU=0
EDGE_AI_ONNX_FORCE_GPU=false
AI_TIMEOUT=30
AI_SEMANTIC_CACHE_MAX_SIZE=5000
AI_SEMANTIC_CACHE_TTL_SEC=86400

SERVER_THREADS=4
DB_POOL_SIZE=10
REDIS_POOL_SIZE=10
LOG_LEVEL=INFO
ENV_MODE=development

CORS_ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080/ws/broadcast
