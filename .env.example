# HeartLake Docker Compose Environment
DB_NAME=heartlake
DB_USER=postgres
DB_PASSWORD=HeartLake
REDIS_PASSWORD=HeartLake
GATEWAY_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
OLLAMA_PORT=11434
BACKEND_PORT=8080
ADMIN_PORT=5173

# AI 本地模型 (Ollama + Qwen)
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL=heartlake-qwen
AI_OLLAMA_FORCE_GPU=false
AI_OLLAMA_NUM_GPU=0
EDGE_AI_ONNX_FORCE_GPU=false
AI_TIMEOUT=30

# Auth Keys
PASETO_KEY=HeartLakeHeartLakeHeartLakeHeartLake
ADMIN_PASETO_KEY=HeartLakeAdminHeartLakeAdminHeartLake
