# HeartLake Backend Environment Configuration
# 模板文件：不要把示例值当成生产默认值。

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_THREADS=4
LOG_LEVEL=INFO
HEARTLAKE_CONFIG_PATH=./config.json
HEARTLAKE_DOCUMENT_ROOT=./public
HEARTLAKE_UPLOAD_PATH=./uploads
CORS_ALLOWED_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=heartlake
DB_USER=postgres
DB_PASSWORD=
DB_POOL_SIZE=20
# 推荐统一使用 DB_CONNECTION_POOL_SIZE（兼容 DB_POOL_SIZE）
DB_CONNECTION_POOL_SIZE=20
DB_TIMEOUT=30

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=12
REDIS_MAX_POOL_SIZE=24

# PASETO Security
# 必填：至少 32 字节
PASETO_KEY=

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASETO_KEY=
ADMIN_CONFIG_FILE=./admin_config.json
# 推荐填写 PBKDF2 哈希（格式: salt:hash）；ADMIN_PASSWORD 不再作为登录默认兜底
ADMIN_PASSWORD_HASH=

# AI Service
# 默认本地 Ollama + Qwen
AI_PROVIDER=ollama
AI_API_KEY=
AI_BASE_URL=http://127.0.0.1:11434
AI_MODEL=heartlake-qwen
# 是否自动拉起/拉取 Ollama（默认关闭，避免占用本机资源）
AI_OLLAMA_AUTOSTART=false
AI_TIMEOUT=30
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=800
# 情绪分析服务化（缓存 + 并发合并 + 自适应调度）
AI_SENTIMENT_LOCAL_CONF_THRESHOLD=0.72
AI_SENTIMENT_CACHE_TTL_SEC=7200
AI_SENTIMENT_CACHE_MAX_SIZE=30000
AI_SENTIMENT_ADAPTIVE_INFLIGHT_THRESHOLD=8
AI_SENTIMENT_ADAPTIVE_LOCAL_CONF_DELTA=0.20
# 强制 GPU（Ollama）
AI_OLLAMA_FORCE_GPU=false
AI_OLLAMA_NUM_GPU=0
AI_OLLAMA_MAIN_GPU=0
AI_OLLAMA_LOW_VRAM=false
# 可选：CPU 线程和上下文长度
AI_OLLAMA_NUM_THREAD=8
AI_OLLAMA_NUM_CTX=4096
# 可选：指定可见 GPU（多卡时）
AI_GPU_DEVICES=0

# Edge AI
EDGE_AI_ENABLED=true
EMBEDDING_DIM=256
EMBEDDING_CACHE_SIZE=20000
# Edge 本地情绪分析高并发缓存（减少重复推理）
EDGE_AI_SENTIMENT_CACHE_TTL_SEC=180
EDGE_AI_SENTIMENT_CACHE_MAX_SIZE=8192

# Performance Tuning (all features enabled by default)
# 启动阶段是否从数据库预热Embedding IDF（低配机建议保持 false）
EMBEDDING_WARMUP_ON_BOOT=false
# 湖神守护服务（默认开启）
ENABLE_LAKE_GOD_GUARDIAN=true
# 湖神首次扫描延迟（秒）与每轮批量上限（控制冷启动峰值）
LAKE_GOD_STARTUP_DELAY_SEC=60
LAKE_GOD_SCAN_BATCH_SIZE=3
# 情绪追踪服务（默认开启）
ENABLE_EMOTION_TRACKING=true
EMOTION_TRACKING_STARTUP_DELAY_SEC=90
# 用户回访服务（默认开启）
ENABLE_USER_FOLLOWUP=true
USER_FOLLOWUP_STARTUP_DELAY_SEC=120
# WebSocket 心跳（默认开启）
ENABLE_WS_HEARTBEAT=true
# 实时双通道：Rust QUIC 网关（默认开启）
REALTIME_QUIC_ENABLED=true
# QUIC 网关监听地址（UDP）
QUIC_GATEWAY_BIND=0.0.0.0:8443

# ONNX 小模型（可选）
# 说明：
# 1) 需要编译时启用 -DHEARTLAKE_USE_ONNX=ON
# 2) EDGE_AI_ONNX_ENABLED=true/false 时为显式开关；不设置则自动探测模型文件
# 3) EDGE_AI_MODEL_PATH 可填目录或文件路径
# 4) EDGE_AI_VOCAB_PATH 为空时默认使用模型目录下 vocab.txt
# 5) 可执行 ./scripts/restore-onnx-model.sh 恢复推荐 INT8 模型与词表
# 6) 可选：EDGE_AI_SENTIMENT_LEXICON_PATH 指向「短语\t权重」领域词典（显式配置才会加载）
# EDGE_AI_ONNX_ENABLED=true
EDGE_AI_MODEL_PATH=./models
# EDGE_AI_VOCAB_PATH=./models/vocab.txt
EDGE_AI_SENTIMENT_LEXICON_PATH=./models/sentiment_domain_lexicon.tsv
EDGE_AI_ONNX_THREADS=1
# ONNX 会话池（高并发建议 2-8，按 CPU 核心调优）
# EDGE_AI_ONNX_SESSION_POOL=4
# 双路策略已内置固定路由与背压，不再暴露路由/过载阈值开关
# ONNX 推理强制 GPU（若运行环境不支持会自动回退 CPU）
EDGE_AI_ONNX_FORCE_GPU=false
EDGE_AI_ONNX_GPU_DEVICE=0
# true=GPU 不可用时直接失败；false=自动回退 CPU
EDGE_AI_ONNX_GPU_HARD_FAIL=false

# Rate Limiting
RATE_AI_PER_HOUR=30

# Public URLs（本地开发可使用 localhost；生产环境应切换到正式 HTTPS/WSS 域名）
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080/ws/broadcast
PUBLIC_QUIC_URL=quic://localhost:8443

# Email (optional)
EMAIL_USER=
EMAIL_PASSWORD=

# Development
ENV_MODE=development
TEST_VERIFICATION_CODE=
