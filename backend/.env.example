# HeartLake Backend Environment Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_THREADS=4
LOG_LEVEL=INFO
HEARTLAKE_CONFIG_PATH=./config.json
HEARTLAKE_DOCUMENT_ROOT=./public
HEARTLAKE_UPLOAD_PATH=./uploads
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=heartlake
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_SIZE=20
DB_TIMEOUT=30

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=30

# PASETO Security (REQUIRED - change in production!)
PASETO_KEY=your-very-strong-paseto-key-32bytes

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_PASETO_KEY=your-admin-paseto-key-32bytes
ADMIN_CONFIG_FILE=./admin_config.json

# AI Service
AI_PROVIDER=deepseek
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TIMEOUT=30
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=800

# Rate Limiting
RATE_AI_PER_HOUR=30

# Public URLs
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080

# Email (optional)
EMAIL_USER=
EMAIL_PASSWORD=

# Development
ENV_MODE=development
TEST_VERIFICATION_CODE=
